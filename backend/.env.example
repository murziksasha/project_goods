PORT=5000
# Listen address for LAN (default 0.0.0.0)
HOST=0.0.0.0
# Replica set is required for finance/sale transactions. Local Docker: npm run db:up
MONGO_URI=mongodb://127.0.0.1:27017/inventory?replicaSet=rs0
# Comma-separated browser origins. Required for CORS in production.
CLIENT_ORIGIN=http://localhost:5173
# Fail multi-doc money/stock ops without replica set (default true when NODE_ENV=production)
# MONGO_REQUIRE_TRANSACTIONS=true
# Idle session expiry in hours (0 = disabled). Example for shop PCs: 72
# AUTH_SESSION_IDLE_HOURS=72
# Server-side OpenWeather key (do not pass apiKey in query)
# OPENWEATHER_API_KEY=
BACKUP_DIR=./backups
# BACKUP_RESTORE_UPLOAD_LIMIT=2gb
# Optional build metadata exposed in GET /api/health (version + buildSha)
# BUILD_SHA=dev
# NODE_ENV=development
# Optional command templates. Available placeholders: {mongoUri}, {archivePath}
# BACKUP_CREATE_COMMAND=mongodump --uri "{mongoUri}" --archive="{archivePath}" --gzip
# BACKUP_RESTORE_COMMAND=mongorestore --uri "{mongoUri}" --archive="{archivePath}" --gzip --drop
